---
import Landing from '../components/Landing.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import client from '../data/client.json';
import { getImage } from 'astro:assets';
import vistaAerea from '../../public/assets/images/vista_aerea.jpg';

const optimizedImage = await getImage({ src: vistaAerea });

const pageTitle = 'Política de Cookies';
const description =
  'Información detallada sobre el uso de cookies en el sitio web del Ayuntamiento de Belmontejo y cómo gestionar sus preferencias.';
---

<BaseLayout title={pageTitle} description={description}>
  <Landing title="🍪 Política de Cookies" image={optimizedImage}>
    <p class="subtitle">
      Información sobre el uso de cookies en el sitio web del {client.name}
      <br />
      <strong>Última actualización:</strong> 25 de octubre de 2025
    </p>
  </Landing>
  <section class="cookie-policy">
    <div class="container">
      <div class="cookie-policy-content">
        <section class="policy-section">
          <h2>¿Qué son las cookies?</h2>
          <p>
            Las cookies son pequeños archivos de texto que se almacenan en su
            dispositivo cuando visita un sitio web. Estas cookies permiten que
            el sitio web reconozca su dispositivo y almacene información sobre
            sus preferencias o acciones anteriores.
          </p>
        </section>

        <section class="policy-section">
          <h2>¿Cómo utilizamos las cookies?</h2>
          <p>
            En el sitio web del {client.name} utilizamos cookies para los siguientes
            propósitos:
          </p>
          <ul>
            <li>Recordar sus preferencias de cookies</li>
            <li>Analizar el tráfico y uso del sitio web</li>
            <li>Mejorar la experiencia de navegación</li>
            <li>Cumplir con obligaciones legales y normativas</li>
          </ul>
        </section>

        <section class="policy-section">
          <h2>Tipos de cookies que utilizamos</h2>

          <div class="cookie-type">
            <h3>🔧 Cookies Necesarias (Siempre activas)</h3>
            <div class="cookie-details">
              <p>
                <strong>Finalidad:</strong> Esenciales para el funcionamiento básico
                del sitio web.
              </p>
              <p><strong>Duración:</strong> Sesión o hasta 1 año</p>
              <p>
                <strong>Datos almacenados:</strong> Preferencias de cookies, configuración
                del sitio
              </p>
              <div class="cookie-list">
                <h4>Cookies específicas:</h4>
                <ul>
                  <li>
                    <code>cookie-consent</code> - Almacena si ha aceptado o rechazado
                    cookies
                  </li>
                  <li>
                    <code>analytics-consent</code> - Almacena su preferencia sobre
                    cookies analíticas
                  </li>
                </ul>
              </div>
            </div>
          </div>

          <div class="cookie-type">
            <h3>📊 Cookies Analíticas (Opcionales)</h3>
            <div class="cookie-details">
              <p>
                <strong>Finalidad:</strong> Nos ayudan a entender cómo los visitantes
                utilizan nuestro sitio web.
              </p>
              <p><strong>Proveedor:</strong> Google Analytics</p>
              <p><strong>Duración:</strong> Hasta 2 años</p>
              <p>
                <strong>Datos almacenados:</strong> Información anónima sobre visitas,
                páginas vistas, tiempo de permanencia
              </p>
              <div class="cookie-list">
                <h4>Cookies de Google Analytics:</h4>
                <ul>
                  <li><code>_ga</code> - Distingue usuarios únicos (2 años)</li>
                  <li>
                    <code>_ga_*</code> - Mantiene el estado de la sesión (2 años)
                  </li>
                  <li>
                    <code>_gid</code> - Distingue usuarios únicos (24 horas)
                  </li>
                </ul>
              </div>
              <p class="privacy-note">
                <strong>Nota de privacidad:</strong> Todas las cookies analíticas
                tienen la anonimización de IP activada para proteger su privacidad.
              </p>
            </div>
          </div>
        </section>

        <section class="policy-section">
          <h2>Sus derechos y opciones</h2>
          <p>
            Usted tiene control total sobre las cookies en nuestro sitio web:
          </p>

          <div class="rights-grid">
            <div class="right-item">
              <h3>✅ Aceptar o Rechazar</h3>
              <p>
                Puede aceptar o rechazar cookies no esenciales en cualquier
                momento.
              </p>
            </div>

            <div class="right-item">
              <h3>⚙️ Configurar Preferencias</h3>
              <p>
                Puede elegir qué tipos de cookies permitir de forma granular.
              </p>
            </div>

            <div class="right-item">
              <h3>🔄 Cambiar Preferencias</h3>
              <p>Puede modificar sus preferencias en cualquier momento.</p>
            </div>

            <div class="right-item">
              <h3>🗑️ Eliminar Cookies</h3>
              <p>Puede eliminar las cookies almacenadas desde su navegador.</p>
            </div>
          </div>

          <div class="manage-cookies">
            <h3>Gestionar sus preferencias de cookies</h3>
            <p>
              Haga clic en el botón siguiente para abrir el panel de
              configuración de cookies:
            </p>
            <button data-js="open-cookie-settings" class="btn-primary">
              Configurar Cookies
            </button>
          </div>
        </section>

        <section class="policy-section">
          <h2>Cómo eliminar cookies desde su navegador</h2>
          <p>
            También puede gestionar o eliminar cookies directamente desde la
            configuración de su navegador. Aquí le explicamos cómo hacerlo en
            los navegadores más comunes:
          </p>

          <div class="browser-instructions">
            <details>
              <summary><strong>Google Chrome</strong></summary>
              <ol>
                <li>
                  Haga clic en los tres puntos (⋮) en la esquina superior
                  derecha
                </li>
                <li>
                  Seleccione "Configuración" &gt; "Privacidad y seguridad" &gt;
                  "Cookies y otros datos del sitio"
                </li>
                <li>Haga clic en "Ver todas las cookies y datos del sitio"</li>
                <li>Busque nuestro sitio web y elimine las cookies</li>
              </ol>
            </details>

            <details>
              <summary><strong>Mozilla Firefox</strong></summary>
              <ol>
                <li>
                  Haga clic en las tres líneas (≡) en la esquina superior
                  derecha
                </li>
                <li>
                  Seleccione "Configuración" &gt; "Privacidad y seguridad"
                </li>
                <li>
                  En "Cookies y datos del sitio", haga clic en "Gestionar datos"
                </li>
                <li>Busque nuestro sitio web y elimine las cookies</li>
              </ol>
            </details>

            <details>
              <summary><strong>Safari</strong></summary>
              <ol>
                <li>Vaya a "Safari" &gt; "Preferencias" &gt; "Privacidad"</li>
                <li>Haga clic en "Gestionar datos del sitio web"</li>
                <li>Busque nuestro sitio web y elimine las cookies</li>
              </ol>
            </details>
          </div>
        </section>

        <section class="policy-section">
          <h2>Base legal y cumplimiento</h2>
          <p>El uso de cookies en nuestro sitio web se basa en:</p>
          <ul>
            <li>
              <strong>Consentimiento:</strong> Para cookies analíticas (Art. 6.1.a
              RGPD)
            </li>
            <li>
              <strong>Interés legítimo:</strong> Para cookies técnicas necesarias
              (Art. 6.1.f RGPD)
            </li>
            <li>
              <strong>Cumplimiento legal:</strong> Según la Ley 34/2002 de Servicios
              de la Sociedad de la Información
            </li>
          </ul>
        </section>

        <section class="policy-section">
          <h2>Contacto</h2>
          <p>
            Si tiene alguna pregunta sobre nuestra política de cookies o desea
            ejercer sus derechos, puede contactarnos:
          </p>
          <div class="contact-info">
            <p>
              <strong>📧 Email:</strong>
              <a href="mailto:{client.email}">{client.email}</a>
            </p>
            <p>
              <strong>📞 Teléfono:</strong>
              <a href="tel:{client.phoneForTel}">{client.phoneFormatted}</a>
            </p>
            <p>
              <strong>📍 Dirección:</strong>
              {client.address.lineOne}, {client.address.lineTwo}, {
                client.address.city
              }
              {client.address.zip}
            </p>
          </div>
        </section>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  // Open cookie settings from the policy page
  document.addEventListener('DOMContentLoaded', function () {
    const openSettingsBtn = document.querySelector(
      '[data-js="open-cookie-settings"]'
    );
    if (openSettingsBtn) {
      openSettingsBtn.addEventListener('click', function () {
        // Show the cookie settings modal if it exists
        const modal = document.querySelector(
          '[data-js="cookie-settings-modal"]'
        );
        if (modal) {
          modal.style.display = 'flex';
          // Set current preferences
          const analyticsConsent =
            localStorage.getItem('analytics-consent') === 'true';
          const analyticsCheckbox = document.querySelector(
            '[data-js="analytics-cookies"]'
          ) as HTMLInputElement;
          if (analyticsCheckbox) {
            analyticsCheckbox.checked = analyticsConsent;
          }
        }
      });
    }
  });
</script>

<style lang="less">
  @import '../styles/pages/politica-de-cookies.less';
</style>
